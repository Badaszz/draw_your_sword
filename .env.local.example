# Public Supabase project values — safe to expose to the browser (RLS protects data)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by scripts/generate-embeddings.mjs to bulk-insert.
# NEVER prefix this with NEXT_PUBLIC_, and never commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
